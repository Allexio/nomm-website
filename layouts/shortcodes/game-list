<ul class="list-group list-group-flush my-4">
  {{- range .Page.Pages.ByTitle -}}
    {{- if not .IsSection -}}
      <li class="list-group-flush d-flex justify-content-between align-items-center py-2 border-bottom">
        <a href="{{ .RelPermalink }}" class="h5 mb-0 text-decoration-none">
          {{ .Title }}
        </a>
        <div class="d-flex align-items-center" style="font-size: 24px;">
          {{- $rating := .Params.rating -}}
          {{- if $rating -}}
            
            {{/* Replicate the exact gradient logic from rating.html */}}
            {{- $gradient := "" -}}
            {{- if eq $rating "gold" -}}
              {{- $gradient = "linear-gradient(135deg, #FFE066 0%, #F5B041 50%, #B7950B 100%)" -}}
            {{- else if eq $rating "silver" -}}
              {{- $gradient = "linear-gradient(135deg, #FFFFFF 0%, #B2BABB 50%, #626567 100%)" -}}
            {{- else if eq $rating "bronze" -}}
              {{- $gradient = "linear-gradient(135deg, #EDBB99 0%, #DC7633 50%, #873A5C 100%)" -}}
            {{- end -}}

            {{/* Render the trophy icon matching your shortcode look */}}
            <i class="fa fa-trophy" style="background: {{ $gradient | safeCSS }}; -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block; font-size: 1.2em;"></i>

          {{- else -}}
            <span class="text-muted small" style="font-size: 14px;">No rating</span>
          {{- end -}}
        </div>
      </li>
    {{- end -}}
  {{- end -}}
</ul>